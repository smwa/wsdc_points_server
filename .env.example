# Copy to .env and adjust for your environment.
DATABASE_URL=postgresql://localhost:5432/wsdc

# --- Data importer ---
# Required to geocode event locations; without it geocoding is skipped (an error
# is logged) and upcoming events are stored without coordinates.
OPEN_WEATHER_MAP_API_KEY=

# Offline test mode: read the legacy raw cache files instead of hitting WSDC.
# Pair with: python -m src.importer --once
IMPORTER_OFFLINE=false
RAW_RESPONSES_PATH=../wsdc_points/points/raw_responses.json.gz
RAW_EVENTS_PATH=../wsdc_points/points/raw_events.html.gz

# Seconds between dancer fetches in live mode (raise to slow the loop down).
IMPORTER_REQUEST_DELAY_SECONDS=30.0
